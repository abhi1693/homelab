#!/usr/bin/env bash
set -euo pipefail

node_major="${1:-}"
if [[ ! "${node_major}" =~ ^[0-9]+$ ]]; then
  echo "Usage: install-node <major-version>" >&2
  exit 2
fi

install -d -m 0755 /etc/apt/keyrings
key_file="$(mktemp)"
trap 'rm -f "${key_file}"' EXIT
curl -fsSL --retry 5 --retry-all-errors --retry-delay 2 --connect-timeout 15 --max-time 120 \
  "https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key" \
  -o "${key_file}"
gpg --dearmor --yes -o /etc/apt/keyrings/nodesource.gpg "${key_file}"
chmod 0644 /etc/apt/keyrings/nodesource.gpg
printf 'deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_%s.x nodistro main\n' "${node_major}" \
  >/etc/apt/sources.list.d/nodesource.list

apt-get update -yq
apt-get install -yq --no-install-recommends nodejs
if ! command -v corepack >/dev/null 2>&1; then
  npm install -g corepack
fi
corepack enable || true
npm cache clean --force
rm -rf /var/lib/apt/lists/*
