+func imageReferenceOptions(image string) []name.Option {
+	registry, _, ok := strings.Cut(image, "/")
+	if ok && registry == "registry.home" {
+		return []name.Option{name.Insecure}
+	}
+
+	return nil
+}
+
+func imageDigestOptions(image string) []remote.Option {
+	platform := os.Getenv("IMAGESCAN_PLATFORM")
+	if platform == "" {
+		registry, _, ok := strings.Cut(image, "/")
+		if ok && registry == "registry.home" {
+			platform = "linux/arm64"
+		}
+	}
+	if platform == "" {
+		return nil
+	}
+
+	parts := strings.Split(platform, "/")
+	if len(parts) < 2 || parts[0] == "" || parts[1] == "" {
+		return nil
+	}
+
+	imagePlatform := v1.Platform{
+		OS:           parts[0],
+		Architecture: parts[1],
+	}
+	if len(parts) >= 3 {
+		imagePlatform.Variant = parts[2]
+	}
+
+	return []remote.Option{remote.WithPlatform(imagePlatform)}
+}
