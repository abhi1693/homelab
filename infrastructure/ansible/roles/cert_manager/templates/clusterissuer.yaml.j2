apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: {{ cert_manager.cluster_issuer_name }}
spec:
  acme:
    email: "{{ cert_manager.acme.email }}"
    server: "{{ cert_manager.acme.server }}"
    privateKeySecretRef:
      name: {{ cert_manager.cluster_issuer_name }}-account-key
    solvers:
      - dns01:
          cloudflare:
            apiTokenSecretRef:
              name: {{ cert_manager.cloudflare_api_token_secret_name }}
              key: api-token
